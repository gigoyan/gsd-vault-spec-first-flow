{
  "schema_version": 1,
  "blueprint_name": "gsd",
  "blueprint_version": "0.1.0",
  "description": "Reusable GSD workflow blueprint manifest for safe project-repository audit-only reporting and approval-gated installation or update sync.",
  "sync_rules": {
    "default_strategy": "project_preserve",
    "never_overwrite_project_runtime": true,
    "require_diff_summary_before_changes": true,
    "require_explicit_user_approval_for_destructive_changes": true,
    "managed_block_markers": {
      "start_prefix": "<!-- GSD-BLUEPRINT:START ",
      "end_prefix": "<!-- GSD-BLUEPRINT:END "
    }
  },
  "ownership_classes": {
    "blueprint_replace": "Replace from blueprint during sync after diff review.",
    "project_preserve": "Never overwrite during blueprint sync.",
    "managed_block": "Update only explicitly marked blueprint-managed blocks.",
    "bootstrap_then_managed_block": "Create the full starter file only when missing; for existing files, update only explicitly marked blueprint-managed guidance blocks and preserve project-owned content.",
    "bootstrap_if_missing": "Create only when missing; preserve existing project copy.",
    "generated_project_local": "Generated per project; not synced from reusable blueprint."
  },
  "files": [
